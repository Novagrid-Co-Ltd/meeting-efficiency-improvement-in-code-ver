# Required (when NOT using Service Account)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Service Account (optional — takes precedence over OAuth above)
GOOGLE_SA_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
GOOGLE_IMPERSONATE_EMAIL=admin@novagrid.tech
WORKSPACE_DOMAIN=novagrid.tech

# LLM
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=
LLM_PROVIDER=gemini

# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Service Auth
API_KEY=your-api-key-for-this-service

# Optional
CALENDAR_ID=ren.fujioka@novagrid.tech
DRIVE_FOLDER_ID=
ADMIN_EMAIL=
CALENDAR_LOOKBACK_DAYS=14
QUICKCHART_BASE_URL=https://quickchart.io
PORT=8080
